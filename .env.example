# Copy this to .env and fill in values before running.
# docker compose reads .env automatically; no manual export needed.

SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Postgres connection string. Omit to fall back to SQLite (useful for `manage.py test`).
DATABASE_URL=postgres://fuelroutes:fuelroutes@db:5432/fuelroutes

# OSRM routing server. Defaults to the public demo server; point to self-hosted for production.
OSRM_BASE_URL=https://router.project-osrm.org

# How far a lat,lng input may be from the nearest US city before being rejected (miles).
MAX_SNAP_MILES=30

# How far off the route a station may sit and still be considered a candidate (miles).
CORRIDOR_BUFFER_MILES=15

# Origins Django allows as CSRF-safe POST sources.
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
